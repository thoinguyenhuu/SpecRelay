{
  "name": "@specrelay/cli",
  "version": "0.1.0-beta.3",
  "private": true,
  "description": "Plan approval and review workflow for Codex and Claude Code.",
  "homepage": "https://github.com/thoinguyenhuu/SpecRelay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thoinguyenhuu/SpecRelay.git"
  },
  "bugs": {
    "url": "https://github.com/thoinguyenhuu/SpecRelay/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "agentic-workflow",
    "claude-code",
    "codex",
    "code-review",
    "developer-tools"
  ],
  "type": "module",
  "bin": {
    "specrelay": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.vi.md",
    "LICENSE",
    ".codex-plugin",
    "skills",
    "templates"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate:plugin": "tsx scripts/validate-plugin.ts",
    "validate:marketplace": "tsx scripts/validate-marketplace.ts",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run validate:plugin && npm run validate:marketplace",
    "package:beta": "npm run validate && tsx scripts/package-beta.ts",
    "test:package": "npm run build && tsx scripts/smoke-beta-package.ts",
    "ci": "npm run validate"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "yaml": "^2.9.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.9"
  }
}
